---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <main class="flex flex-col justify-between h-screen">
            <div class="flex justify-between items-center p-6">
                <h2 class="text-sm font-mono text-stone-900 uppercase">A Studio</h2>
                <h3 class="text-sm font-mono text-stone-900 uppercase">Video Games / Web Applications / Cross-Platform Apps</h3>
            </div>
            <div class="flex items-center justify-center text-base">
                <h1 class="text-[16.5vw] -mt-16 font-display text-left leading-[0.8] text-stone-300">Unusual<br />Undertaking</h1>
            </div>
        <section class="flex justify-between items-center p-6">
            <h3 class="text-sm font-mono text-stone-900 uppercase">Blending art + design + engineering to create digital things that people love.</h3>
            <p class="text-sm font-mono text-stone-900 uppercase">email (at) unusualundertaking.com</p>
        </section>
    </main>
</Layout>
